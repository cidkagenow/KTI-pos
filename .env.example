# Environment: "development" or "production"
ENVIRONMENT=development

# Database
POSTGRES_USER=ktipos
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB=ktipos
DATABASE_URL=postgresql://ktipos:CHANGE_ME_STRONG_PASSWORD@localhost:5432/ktipos

# Security — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_GENERATE_A_RANDOM_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS — comma-separated origins. Use "*" for development only.
# Production example: CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=*

# Peru Consult API (RUC/DNI lookup)
PERU_CONSULT_API_TOKEN=

# SUNAT Direct Integration
# Set SUNAT_ENV=production when ready to send real invoices
SUNAT_ENV=beta
SUNAT_SOL_USER=MODDATOS
SUNAT_SOL_PASSWORD=moddatos
SUNAT_CERT_PATH=/app/certs/CertificadoPFX.pfx
SUNAT_CERT_PASSWORD=

# Empresa
EMPRESA_RUC=20525996957
EMPRESA_RAZON_SOCIAL=INVERSIONES KTI D & E E.I.R.L.
EMPRESA_DIRECCION=

# Gemini AI (chatbot)
GEMINI_API_KEY=

# SMTP (Gmail app password)
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
