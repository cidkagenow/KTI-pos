# Stage 1: Build POS frontend
FROM node:20-alpine AS build-pos
WORKDIR /app
RUN npm install -g pnpm
COPY frontend/package.json frontend/pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile
COPY frontend/ .
RUN pnpm build

# Stage 2: Nginx serves POS frontend
FROM nginx:alpine
COPY --from=build-pos /app/dist /usr/share/nginx/html
EXPOSE 80
